# Azure Synapse Dedicated SQL Pool connection
SYNAPSE_SERVER=your-workspace.sql.azuresynapse.net
SYNAPSE_DATABASE=your-dedicated-pool-name

# Azure AD App Registration (service principal) used to authenticate to Synapse
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-app-registration-client-secret

# Note: the event title is no longer a server env var. It's defined in
# js/config.js (window.APP_CONFIG.eventTitle) and sent from the client on submit.
